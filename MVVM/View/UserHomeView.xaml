<UserControl x:Class="PassManaAlpha.MVVM.View.UserHomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PassManaAlpha.MVVM.View"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <Storyboard x:Key="FadeOutStoryboard">
            <DoubleAnimation Storyboard.TargetName="kazusa"  Storyboard.TargetProperty="Opacity" From="1" To="0" BeginTime="0:0:1" Duration="0:0:2"/>
        </Storyboard>
    </UserControl.Resources>
    <Grid>
        <Image x:Name="kazusa" Source="/assets/Home.jpg"  Width="688" Stretch="UniformToFill" HorizontalAlignment="Center"  VerticalAlignment="Center" Margin="0,-2,0,0" Visibility="Hidden"
       Opacity="0"/>
        <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" Margin="224,0,0,0" Width="386" Height="141">
            <StackPanel.Background>
                <SolidColorBrush Color="Black" Opacity="0.5"/>
            </StackPanel.Background>
            <TextBlock Text="Welcome to PassManaAlpha!" FontSize="24" FontWeight="Bold" 
               Margin="0,0,0,20" HorizontalAlignment="Center" Foreground="White"/>
            <TextBlock Text="Your random project name>" FontSize="16" FontWeight="Light" 
               HorizontalAlignment="Center" Foreground="White"/>
            <Button Content="call the maid>?" Click="Button_Click" Width="150" Height="40" Margin="0,20,0,0" HorizontalAlignment="Center" Style="{StaticResource LocalTypical}"/>
        </StackPanel>
    </Grid>
    
</UserControl>
