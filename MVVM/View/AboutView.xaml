<UserControl x:Class="PassManaAlpha.MVVM.View.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800" Background="Transparent">

    <Grid>
        <MediaElement x:Name="BgVideo"
                  Source="pack://siteoforigin:,,,/assets/kazusa_L2D.mp4"
                  LoadedBehavior="Manual"
                  UnloadedBehavior="Stop"
                  IsMuted="True"
                  Stretch="UniformToFill">
            <MediaElement.Effect>
                <BlurEffect Radius="8"/>
            </MediaElement.Effect>
        </MediaElement>
        <Border Background="#AA403850"/>

        <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>

        <!-- Left: App Info -->
        <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">

            <TextBlock Text="{Binding AppName}" FontSize="32" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>

            <TextBlock Text="{Binding Version}" FontSize="13"
                       Foreground="#a38ca3"
                       Margin="0,0,0,20"/>

            <TextBlock Text="{Binding Description}"
                       FontSize="14"
                       Foreground="#CCCCCC"
                       TextWrapping="Wrap"
                       MaxWidth="340"
                       Margin="0,0,0,24"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Author  " Foreground="#a38ca3" FontSize="13" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding Author}" Foreground="White" FontSize="13"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Stack   " Foreground="#a38ca3" FontSize="13" FontWeight="SemiBold"/>
                <TextBlock Text="WPF · .NET 8 · AES-256 · PBKDF2" Foreground="White" FontSize="13"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Storage " Foreground="#a38ca3" FontSize="13" FontWeight="SemiBold"/>
                <TextBlock Text="Local encrypted flat-file vault" Foreground="White" FontSize="13"/>
            </StackPanel>

        </StackPanel>
            <Border Background="#643566" CornerRadius="12" Margin="535,20,20,20" Padding="12" Grid.ColumnSpan="2">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="245">
                    <Border CornerRadius="8" ClipToBounds="True"
                        Width="225" Height="343">
                        <Image Source="{Binding WaifuImage}"
                           Stretch="UniformToFill"
                           RenderOptions.BitmapScalingMode="HighQuality" Margin="1,1,-1,-27">
                            <Image.Effect>
                                <BlurEffect Radius="0"/>
                            </Image.Effect>
                        </Image>
                    </Border>


                    <TextBlock Text="{Binding WaifuName}" Foreground="White" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,10,0,2"/>
                    <TextBlock Text="{Binding WaifuSeries}" Foreground="#a38ca3" FontSize="11" HorizontalAlignment="Center"/>
                    <TextBlock Foreground="#a38ca3" FontSize="11" Height="19" Width="209" TextAlignment="Center"><Hyperlink x:Name="Link" Foreground="#c084fc" RequestNavigate="Hyperlink_RequestNavigate" NavigateUri="https://www.pixiv.net/en/users/22932449"><Run Text="Image Source"/></Hyperlink></TextBlock>

                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>