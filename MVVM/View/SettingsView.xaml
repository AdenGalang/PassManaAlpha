<UserControl x:Class="PassManaAlpha.MVVM.View.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             Background="#FF403850">
 
        
   

    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="320">
        

        <TextBlock Text="Settings"
                   FontSize="22" FontWeight="Bold"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,24"/>

        
        <Border Background="#643566" CornerRadius="8" Padding="20">
            <StackPanel>
                <TextBlock Text="Master Key"
                           Foreground="#F0C0F0"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6"/>

                <TextBlock Text="Used to encrypt and decrypt your vault. Keep it safe — if you lose it, your vault cannot be recovered."
                           Foreground="#AAAAAA"
                           FontSize="11"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"/>

                <!-- Show/hide toggle on the key field -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <PasswordBox x:Name="MasterKeyBox"
                                 Grid.Column="0"
                                 Height="34"
                                 VerticalContentAlignment="Center"
                                 Padding="8,0"
                                 FontSize="14"
                                 Background="#2D2F38"
                                 Foreground="White"
                                 BorderBrush="#a38ca3"
                                 BorderThickness="1"
                                 PasswordChanged="MasterKeyBox_PasswordChanged"/>

                    <Button Grid.Column="1"
                            Width="34" Height="34"
                            Margin="6,0,0,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="Reveal key"
                            Click="RevealKey_Click">
                        <TextBlock x:Name="RevealIcon" Text="🔒" FontSize="14"/>
                    </Button>
                </Grid>

                <!-- Revealed plaintext (hidden by default) -->
                <TextBox x:Name="MasterKeyPlain"
                         Visibility="Collapsed"
                         Height="34"
                         VerticalContentAlignment="Center"
                         Padding="8,0"
                         FontSize="14"
                         Background="#2D2F38"
                         Foreground="White"
                         BorderBrush="#a38ca3"
                         BorderThickness="1"
                         Text="{Binding MasterKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <StackPanel Orientation="Horizontal" Margin="0,14,0,0" HorizontalAlignment="Right">
                    <Button Content="Set to Default"
                            Style="{StaticResource LocalTypical}"
                            Width="110" Height="32"
                            Margin="0,0,8,0"
                            Background="#3A3A40"
                            Command="{Binding SetDefaultCommand}"
                            Click="SetDefault_SyncBox"/>
                    <Button Content="Save Key"
                            Style="{StaticResource LocalTypical}"
                            Width="90" Height="32"
                            Background="#752f49"
                            Command="{Binding SaveKeyCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <TextBlock Text="⚠ The config file stores the master key in plaintext."
                   Foreground="#CC8800"
                   FontSize="10"
                   TextWrapping="Wrap"
                   Margin="0,12,0,0"
                   HorizontalAlignment="Center"/>
        
    </StackPanel>
</UserControl>